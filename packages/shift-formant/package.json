{
  "name": "@audio/shift-formant",
  "version": "1.1.3",
  "description": "Formant-preserving pitch shift via cepstral envelope re-imposition",
  "type": "module",
  "sideEffects": false,
  "main": "index.js",
  "exports": {
    ".": "./index.js",
    "./audio": {
      "types": "./audio.d.ts",
      "default": "./audio.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "index.js",
    "audio.js",
    "host.js",
    "audio.d.ts"
  ],
  "dependencies": {
    "fourier-transform": "^2.3.0",
    "@audio/spectral-pvoc": "^1.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "audiojs",
  "homepage": "https://github.com/audiojs/shift/tree/main/packages/shift-formant#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/audiojs/shift.git",
    "directory": "packages/shift-formant"
  },
  "keywords": [
    "audio",
    "pitch-shift",
    "formant",
    "cepstral",
    "voice",
    "timbre",
    "dsp"
  ],
  "engines": {
    "node": ">=18"
  },
  "audio": "./audio.js"
}
